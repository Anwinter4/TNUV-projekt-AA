<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/ustvariNalepko"
    android:background="#FEF8FA"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#F5C7D4"
        app:contentInsetStart="0dp"
        app:contentInsetLeft="0dp">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:padding="5dp"
            android:layout_marginLeft="10dp"
            android:id="@+id/naslovUstvariNalepko"
            android:text="Ustvari Nalepko"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#C06084"
            android:layout_weight="1"/>
        <ImageButton
            android:id="@+id/addUstvariNalepkoPink"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_ustvari_nalepko_pink"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_gravity="center">

        <ImageButton
            android:id="@+id/btnReverse"
            android:src="@drawable/ic_reverse"
            android:layout_height="50dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:backgroundTint="@android:color/transparent"/>

        <ImageButton
            android:id="@+id/btnRedo"
            android:src="@drawable/ic_redo"
            android:layout_height="50dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:backgroundTint="@android:color/transparent"/>


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="8dp">

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_weight="2"
            android:fillViewport="true"
            android:layout_marginEnd="8dp"
            android:layout_gravity="center_vertical"
            android:foreground="@drawable/greyboarder">

            <si.uni_lj.fe.tnuv.artly.NalepkaView
                android:id="@+id/canvasNalepka"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingRight="200dp"
                android:layout_gravity="center_vertical"
                android:background="#FFFFFF"/>
        </FrameLayout>


        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/costumboarder"
            android:gravity="center">

            <ImageButton
                android:id="@+id/previousArrow"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_up"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/elementRecyclerView"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="4dp" />

            <ImageButton
                android:id="@+id/nextArrow"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_down"
                android:background="?attr/selectableItemBackgroundBorderless" />

                    </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F5C7D4">

        <ImageButton
            android:id="@+id/btnTrash"
            android:src="@drawable/ic_delete"
            android:layout_height="50dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"/>

        <ImageButton
            android:id="@+id/btnEraser"
            android:src="@drawable/ic_eraser"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent" />

        <LinearLayout
            android:layout_height="60dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            >
            <ImageButton
                android:id="@+id/btnPencil"
                android:src="@drawable/ic_pencil"
                android:layout_height="50dp"
                android:layout_width="match_parent"
                android:backgroundTint="@android:color/transparent"/>
            <View
                android:id="@+id/preview_selected_color"
                android:layout_width="50dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:background="@android:color/black" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPlus"
            android:src="@drawable/ic_add_picture"
            android:layout_height="50dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"/>

        <ImageButton
            android:id="@+id/btnExport"
            android:src="@drawable/ic_export"
            android:layout_height="50dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="#F5C7D4">

        <Button
            android:id="@+id/btnPreklici"
            android:layout_width="150dp"
            android:layout_height="60dp"
            android:text="Prekliči"
            android:textSize="20sp"
            android:backgroundTint="#C06084"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnShrani"
            android:layout_width="150dp"
            android:layout_height="60dp"
            android:text="Shrani"
            android:textSize="20sp"
            android:backgroundTint="#C06084"/>
    </LinearLayout>

</LinearLayout>